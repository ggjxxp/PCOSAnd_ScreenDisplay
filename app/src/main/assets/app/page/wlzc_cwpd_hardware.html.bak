</select>
 <input type="button" value="打印" class="login_btn" onClick="javascript:setSoftVer('print_newall');"   style="width:100px;background:url('../main_img/button_normal.9.png');background-size:100px 48px; background-repeat:no-repeat; "  />
  <input type="button" value="设置模板" class="login_btn" onClick="javascript:setSoftVer('print_settmp');"   style="width:100px;background:url('../main_img/button_normal.9.png');background-size:100px 48px; background-repeat:no-repeat; "  />

   <input type="button" value="读取模板" class="login_btn" onClick="javascript:setSoftVer('print_gettmp');"   style="width:100px;background:url('../main_img/button_normal.9.png');background-size:100px 48px; background-repeat:no-repeat; "  />
 </p>

