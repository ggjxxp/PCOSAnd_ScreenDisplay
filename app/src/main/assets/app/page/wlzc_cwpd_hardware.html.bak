<option value="-1|0">请选择USB</option>
</select>
 <input type="button" value="设置默认USB打印" class="login_btn" onClick="javascript:setSoftVer('setDefault_usb');"   style="width:180px;background:url('../main_img/button_normal.9.png');background-size:180px 48px; background-repeat:no-repeat; "  />
<br><br> 
 </p>


 <p class="btn_login">
    <input type="button" value="测试读取串口数据" class="login_btn" onClick="javascript:setSoftVer('get_serial');"   style="width:180px;background:url('../main_img/button_normal.9.png');background-size:100px 48px; background-repeat:no-repeat; "  />

	 <input type="button" value="测试打印标签" class="login_btn" onClick="Cyber_JsPrinterStandard.cyber_printlabeltest();"   style="width:180px;background:url('../main_img/button_normal.9.png');background-size:100px 48px; background-repeat:no-repeat; "  />
<br><br> 
<br><br> 
 </p>



 	<img src="../main_img/toolbarbkimagee.png" style="height:30px;width:100%;">
<p class="btn_login">
<p class="btn_login" style="background:#fffffde4;background-size:90px 47px;color:#fff;">
高级打印 &nbsp; &nbsp;模板<select name="print_tmp" id="print_tmp" style="width:180px; height:48px; background:url('../main_img/button_normal.9.png');background-size:180px 48px; background-repeat:no-repeat; ">
<option value="-1|0">请选择模板</option>
<option value="testmix">test混合</option>
<option value="order">订单</option>
<option value="pos">pos</option>

</select>
接口 &nbsp; &nbsp;<select name="print_interface" id="print_interface" style="width:180px; height:48px; background:url('../main_img/button_normal.9.png');background-size:180px 48px; background-repeat:no-repeat; ">
<option value="-1|0">请选择接口方式</option>
<option value="usb">USB</option>
<option value="net">网络</option>
<option value="http">网络</option>
<option value="blue">蓝牙</option>
<option value="driver">驱动</option>
