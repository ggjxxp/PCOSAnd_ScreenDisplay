<center>
<h2 style="color:#000;">硬件测试</h2>
 

 
<br><br>
<p class="btn_login" style="background:#fffffde4;background-size:90px 47px;color:#fff;">
  IP/蓝牙/USB<input type="txt" value="192.168.1.198" class="login_btn" id="ip"  name="ip"  style=" border:0px solid;background:url('../main_img/editview_bk_image.9.png');background-size:240px 48px;width:240px;"  />端口
   <input type="txt" value="" class="login_btn" id="port"  style=" border:0px solid;background:url('../main_img/editview_bk_image.9.png');background-size:90px 48px;"   /><br>
   <input type="txt" value="测试打印内容" class="login_btn" id="printdata_s"  style=" border:0px solid;background:url('editview_bk_image.9.png');background-size:3000px 48px;width:300px;" /><br>

   <input type="button" value="打印测试" class="login_btn" onClick="javascript:setSoftVer('test_print_net');"    />
     <input type="button" value="测试厨房" class="login_btn" onClick="javascript:setSoftVer('test_print_net2');"    />

	   <input type="button" value="测试模板" class="login_btn" onClick="javascript:setSoftVer('test_print_net_tmp');"    />


  <input type="button" value="蓝牙" class="login_btn" onClick="javascript:setSoftVer('test_print_blue');"    />
  <input type="button" value="USB" class="login_btn" onClick="javascript:setSoftVer('test_print_usb');"    />
  <input type="button" value="打印机选择" class="login_btn" onClick="javascript:setSoftVer('test_print_select');"    />
 
 </p>
<p class="btn_login">
<p class="btn_login" style="background:#fffffde4;background-size:90px 47px;color:#fff;">
