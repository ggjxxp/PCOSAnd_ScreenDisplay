<style>

html, body, div, p, ul, li, dl, dt, dd, h1, h2, h3, h4, h5, h6, form, input, select, button, textarea, iframe, table, th, td {
	margin: 0;
	padding: 0;
	border-spacing:0px !important;
	outline:medium;
	word-break:break-word;
	border:none;
	list-style:none;
}
body{
 display:inline; 
 text-align:center
border:0px solid #000;

 
     background:url('../main_img/desktop_1.jpg');
 
    
    background-size: cover;

	 /*鼠标*/
 -webkit-touch-callout: none; 
 -webkit-user-select: none;  
 -khtml-user-select: none; 
 -moz-user-select: none; 
 -ms-user-select: none; 
 user-select: none;

 background-repeat: no-repeat;
 
  background-attachment: fixed;

}

input {
background:url('../main_img/button_normal.9.png');
color:#ff8f40;
font-size:14pt;
width:90px;
height:50px;
/*
 -webkit-background-size: cover !important;
    -moz-background-size: cover !important;
    -o-background-size: cover !important;
	
    background-size: cover !important;
	*/
	 -webkit-background-size: 90px 48px; background-repeat:no-repeat; 
    -moz-background-size: 90px 48px; background-repeat:no-repeat; 
    -o-background-size: 90px 48px; background-repeat:no-repeat; 
	 background-size:90px 48px; background-repeat:no-repeat; 


}

btn_back
{
background:url('../main_img/toolbar_back_normall.png');
color:#ff8f40;
font-size:14pt;
width:90px;
height:50px;
/*
 -webkit-background-size: cover !important;
    -moz-background-size: cover !important;
    -o-background-size: cover !important;
	
    background-size: cover !important;
	*/
	 -webkit-background-size: 90px 48px; background-repeat:no-repeat; 
    -moz-background-size: 90px 48px; background-repeat:no-repeat; 
    -o-background-size: 90px 48px; background-repeat:no-repeat; 
	 background-size:90px 48px; background-repeat:no-repeat; 
}

.canvas{
		border:1px solid black;
		/*位置绝对*/
		position: absolute;
		top: 0;
		left: 110;
		/*设置所在层数，在上层*/
		z-index: 1;
	}
	.canvas_bgp{
		width: 1366px;
		height: 414px;
		/*位置绝对*/
		position: absolute;
		top: 0;
		left: 110;
	}
	.btn_groud_css{
	     margin-top:60px;
		 
