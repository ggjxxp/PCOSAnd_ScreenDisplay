<option value="cache_db">数据库存储</option>
</select>
 <input type="button" value="设置" class="login_btn" onClick="javascript:setSoftConfig2('LocalCache','DefaultHome_Load_From','defaulthomeloadfrom');"   style="width:60px;height:32px;background-repeat:no-repeat; "  />
<br><br> 
 </p>







