<div class="btn_groud_css">
<center>
<h2 style="color:#000;">设备参数</h2>
 

 
<br><br>
 
 


  



 <script>
 function setSoftConfig2(sec,key,v_id){
	// alert("当前：:"+sec);
	   var value=$("#"+v_id).val();

	 CyberWin_JsStandardPlug.cwpd_system_set(sec,key,value,"20225578-2019");
	  var d= CyberWin_JsStandardPlug.cwpd_system_get(sec,key,"20225578-2019");
	  alert("当前：:"+d);
 }
 </script>

 <p class="btn_login" style="background:#ffffff;background-size:90px 47px;">
核心缓存 &nbsp; &nbsp;<select name="localcache_kernel" id="localcache_kernel" style="width:180px; height:32px;border: 1px solid black;background-size:180px 48px; background-repeat:no-repeat; ">
<option value="0">取消缓存</option>
<option value="1">优先用户</option>
<option value="2">禁止联网</option>
<option value="3">禁止用户端</option>
<option value="4">默认</option>
</select>
 <input type="button" value="设置" class="login_btn" onClick="javascript:setSoftConfig2('LocalCache','kernel','localcache_kernel');"   style="width:60px;height:32px;border: 1px solid black;background-size:60px 48px; background-repeat:no-repeat; "  />
 
图像加速 &nbsp; &nbsp;<select name="localcache_image" id="localcache_image" style="width:180px; height:32px;border: 1px solid black; background-repeat:no-repeat; ">
<option value="0">关闭</option>
<option value="1">开启</option>
 
</select>
 <input type="button" value="设置" class="898" onClick="javascript:setSoftConfig2('LocalCache','kernel','localcache_image');"   style="width:60px;height:32px;border: 1px solid black;"  />
<br><br> 
 </p>


  <p class="btn_login" style="background:#ffffff;background-size:90px 47px;">
会话技术 &nbsp; &nbsp;<select name="start_mode" id="start_mode" style="width:180px; height:32px;border: 1px solid black; background-repeat:no-repeat; ">
<option value="-1">请选择</option>
<option value="system">未来之窗</option>
<option value="app">客户</option>
</select>
 <input type="button" value="设置" class="login_btn" onClick="javascript:alert('联系开发商');"   style="width:60px; height:32px;background-repeat:no-repeat; "  />
  </p>


 <p class="btn_login" style="background:#ffffff;background-size:90px 47px;">

资源加速 &nbsp; &nbsp;<select name="resource" id="resource" style="width:180px; height:32px;border: 1px solid black; background-repeat:no-repeat; ">
<option value="-1">请选择</option>
<option value="0">关闭</option>
<option value="1">未来之窗资源技术</option>
</select>
 <input type="button" value="设置" class="login_btn" onClick="javascript:setSoftConfig2('LocalCache','resource','resource');"   style="width:60px;height:32px;background-repeat:no-repeat; "  />
<br><br> 
 </p>


  <p class="btn_login" style="background:#ffffff;background-size:90px 47px;">


  无法访问操作 &nbsp; &nbsp;<select name="NoNetworkDefaultErrorFrom" id="NoNetworkDefaultErrorFrom" style="width:180px; height:32px;border: 1px solid black; background-repeat:no-repeat; ">
<option value="-1">请选择</option>
<option value="Local">本地数据</option>
<option value="set">系统设定</option>
<option value="defaulterror">系统默认界面</option>
<option value="login">系统默认界面</option>
</select>
 <input type="button" value="设置" class="login_btn" onClick="javascript:setSoftConfig2('LocalCache','NoNetworkDefaultErrorFrom','NoNetworkDefaultErrorFrom');"   style="width:60px;height:32px;background-repeat:no-repeat; "  />
<br><br> 
 </p>






   <p class="btn_login" style="background:#ffffff;background-size:90px 47px;">




资源存储 &nbsp; &nbsp;<select name="resource_path" id="resource_path" style="width:180px; height:32px;border: 1px solid black; background-repeat:no-repeat; ">
<option value="-1">请选择</option>
<option value="%CyberWinPHP_Path%/CyberCache/">未来之窗安装</option>
